{
  "name": "nova-dsl-support",
  "displayName": "NOVA DSL Support",
  "description": "Syntax highlighting for the NOVA DSL (.myext, .nova)",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "nova",
        "aliases": [
          "NOVA",
          "nova"
        ],
        "extensions": [
          ".myext",
          ".nova"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nova",
        "scopeName": "source.nova",
        "path": "./nova.tmLanguage.json"
      }
    ]
  }
}
