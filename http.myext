let __http_port: int = 80;
let __http_html_payload: string = "<h1>NOVA HTTP Server</h1>";

fn configureWebServer(port: int, htmlPayload: string) -> void {
    __http_port = port;
    __http_html_payload = htmlPayload;
}

@core(0)
@rate(1ms)
task startWebServer() {
    unsafe {
        // Guard against race conditions: bind sockets only after WiFi is connected.
        while (WiFi.status() != WL_CONNECTED) {
            vTaskDelay(500 / portTICK_PERIOD_MS);
        }

        // Heap allocation avoids placing a heavy WebServer instance on task stack.
        static WebServer* server = nullptr;
        static bool serverStarted = false;

        if (!serverStarted) {
            server = new WebServer(__http_port);
            // Keep route callback minimal to avoid long task stalls under request load.
            server->on("/", []() {
                server->send(200, "text/html", __http_html_payload.c_str());
            });
            server->begin();
            serverStarted = true;
        }

        while (true) {
            if (server != nullptr) {
                server->handleClient();
            }
            // Cooperative yield keeps networking responsive and avoids watchdog trips.
            vTaskDelay(10 / portTICK_PERIOD_MS);
        }
    }
}
