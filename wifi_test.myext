import "wifi.myext";

let PIXEL_PIN:int = 48;
let wifiConnected: bool = false;
let blinkPhase: bool = false;

gpioMode(PIXEL_PIN, out);

let cfg: WiFiConfig = WiFiConfig(
    ssid: "galit",
    password: "0544700432"
);

connectWiFi(cfg);

@core(0)
@rate(500ms)
task wifiStatusBlink() {
    unsafe {
        wifiConnected = (WiFi.status() == WL_CONNECTED);
    }

    blinkPhase = !blinkPhase;

    if (wifiConnected) {
        if (blinkPhase) {
            rgbWrite(PIXEL_PIN, 0, 32, 0);
        } else {
            rgbWrite(PIXEL_PIN, 0, 0, 0);
        }
    } else {
        if (blinkPhase) {
            rgbWrite(PIXEL_PIN, 32, 0, 0);
        } else {
            rgbWrite(PIXEL_PIN, 0, 0, 0);
        }
    }
}
